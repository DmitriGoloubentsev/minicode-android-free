{
	"name": "Markdown",
	"scopeName": "text.html.markdown",
	"patterns": [
		{ "include": "#heading" },
		{ "include": "#blockquote" },
		{ "include": "#fenced_code_block" },
		{ "include": "#link" },
		{ "include": "#image" },
		{ "include": "#bold" },
		{ "include": "#italic" },
		{ "include": "#strikethrough" },
		{ "include": "#inline_code" },
		{ "include": "#horizontal_rule" },
		{ "include": "#list_item" },
		{ "include": "#raw_link" }
	],
	"repository": {
		"heading": {
			"patterns": [
				{
					"match": "^(#{1,6})\\s+(.+)$",
					"captures": {
						"1": { "name": "punctuation.definition.heading.markdown" },
						"2": { "name": "markup.heading.markdown" }
					},
					"name": "markup.heading.markdown"
				}
			]
		},
		"blockquote": {
			"match": "^\\s*(>)\\s?(.*)$",
			"captures": {
				"1": { "name": "punctuation.definition.quote.begin.markdown" },
				"2": { "name": "markup.quote.markdown" }
			},
			"name": "markup.quote.markdown"
		},
		"fenced_code_block": {
			"begin": "^\\s*(`{3,}|~{3,})\\s*(\\w*)?\\s*$",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.markdown" },
				"2": { "name": "fenced_code.block.language.markdown" }
			},
			"end": "^\\s*\\1\\s*$",
			"endCaptures": {
				"0": { "name": "punctuation.definition.markdown" }
			},
			"name": "markup.fenced_code.block.markdown",
			"contentName": "meta.embedded.block.markdown"
		},
		"link": {
			"match": "(\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))",
			"captures": {
				"1": { "name": "punctuation.definition.link.markdown" },
				"2": { "name": "string.other.link.title.markdown" },
				"3": { "name": "punctuation.definition.link.markdown" },
				"4": { "name": "punctuation.definition.link.markdown" },
				"5": { "name": "markup.underline.link.markdown" },
				"6": { "name": "punctuation.definition.link.markdown" }
			}
		},
		"image": {
			"match": "(!)\\[(.*?)\\]\\((.*?)\\)",
			"captures": {
				"1": { "name": "punctuation.definition.image.markdown" },
				"2": { "name": "string.other.link.description.markdown" },
				"3": { "name": "markup.underline.link.image.markdown" }
			}
		},
		"bold": {
			"match": "(\\*\\*|__)(?=\\S)(.+?)(?<=\\S)(\\1)",
			"captures": {
				"1": { "name": "punctuation.definition.bold.markdown" },
				"2": { "name": "markup.bold.markdown" },
				"3": { "name": "punctuation.definition.bold.markdown" }
			},
			"name": "markup.bold.markdown"
		},
		"italic": {
			"match": "(?<![\\*_])(\\*|_)(?=\\S)(.+?)(?<=\\S)(\\1)(?![\\*_])",
			"captures": {
				"1": { "name": "punctuation.definition.italic.markdown" },
				"2": { "name": "markup.italic.markdown" },
				"3": { "name": "punctuation.definition.italic.markdown" }
			},
			"name": "markup.italic.markdown"
		},
		"strikethrough": {
			"match": "(~~)(.+?)(~~)",
			"captures": {
				"1": { "name": "punctuation.definition.strikethrough.markdown" },
				"2": { "name": "markup.strikethrough.markdown" },
				"3": { "name": "punctuation.definition.strikethrough.markdown" }
			},
			"name": "markup.strikethrough.markdown"
		},
		"inline_code": {
			"match": "(`+)(.+?)(\\1)",
			"captures": {
				"1": { "name": "punctuation.definition.raw.markdown" },
				"2": { "name": "markup.inline.raw.string.markdown" },
				"3": { "name": "punctuation.definition.raw.markdown" }
			},
			"name": "markup.inline.raw.string.markdown"
		},
		"horizontal_rule": {
			"match": "^\\s*([-*_]){3,}\\s*$",
			"name": "meta.separator.markdown"
		},
		"list_item": {
			"match": "^\\s*([-*+]|\\d+\\.)\\s",
			"captures": {
				"1": { "name": "punctuation.definition.list.begin.markdown" }
			}
		},
		"raw_link": {
			"match": "(<)(https?://[^>]+)(>)",
			"captures": {
				"1": { "name": "punctuation.definition.link.markdown" },
				"2": { "name": "markup.underline.link.markdown" },
				"3": { "name": "punctuation.definition.link.markdown" }
			}
		}
	}
}

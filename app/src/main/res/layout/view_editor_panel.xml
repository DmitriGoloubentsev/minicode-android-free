<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background">

    <!-- Tab bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/dark_surface">

        <HorizontalScrollView
            android:id="@+id/tab_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginEnd="144dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tab_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_git_diff"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_git_diff"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Git Diff"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_git_log"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_git_log"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Git Log"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_find"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_search"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Find"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_save"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_save"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save"
                android:visibility="gone" />

        </LinearLayout>

    </FrameLayout>

    <!-- Path bar -->
    <TextView
        android:id="@+id/text_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="2dp"
        android:textSize="10sp"
        android:textColor="@color/dark_text_secondary"
        android:maxLines="1"
        android:ellipsize="start"
        android:background="@color/dark_surface_variant"
        android:visibility="gone" />

    <!-- Search bar (inline, hidden by default) -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#FF252526"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:hint="Find"
            android:textSize="13sp"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/dark_text_secondary"
            android:background="@color/dark_background"
            android:paddingHorizontal="8dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <TextView
            android:id="@+id/search_match_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text_secondary"
            android:textSize="11sp"
            android:layout_marginHorizontal="6dp"
            android:text="0/0" />

        <ImageView
            android:id="@+id/btn_search_prev"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_up"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous match" />

        <ImageView
            android:id="@+id/btn_search_next"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_down"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next match" />

        <ImageView
            android:id="@+id/btn_search_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close search" />

    </LinearLayout>

    <!-- Editor area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- sora-editor CodeEditor -->
        <io.github.rosemoe.sora.widget.CodeEditor
            android:id="@+id/code_editor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- WebView (for HTML files) -->
        <WebView
            android:id="@+id/web_viewer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/dark_background" />

        <!-- PDF viewer (lazy-rendered pages) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pdf_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="#FFFFFFFF" />

        <!-- Image viewer (for image files) -->
        <ScrollView
            android:id="@+id/image_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/dark_background">

            <ImageView
                android:id="@+id/image_viewer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="Image preview" />

        </ScrollView>

        <!-- Git panel (diff viewer / commit log) -->
        <LinearLayout
            android:id="@+id/git_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/dark_background"
            android:visibility="gone">

            <!-- Git panel header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="#FF252526"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/git_panel_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/dark_text"
                    android:textSize="12sp"
                    android:text="Git Diff" />

                <ImageView
                    android:id="@+id/btn_git_panel_close"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Close" />
            </LinearLayout>

            <!-- Scrollable content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/git_panel_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textColor="@color/dark_text"
                    android:textSize="11sp"
                    android:typeface="monospace"
                    android:textIsSelectable="true" />
            </ScrollView>

        </LinearLayout>

        <!-- Git commit log list -->
        <LinearLayout
            android:id="@+id/git_log_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/dark_background"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="#FF252526"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/dark_text"
                    android:textSize="12sp"
                    android:text="Git Log" />

                <ImageView
                    android:id="@+id/btn_git_log_close"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Close" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/git_log_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- Empty state -->
        <TextView
            android:id="@+id/text_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Open a file from the file tree"
            android:textColor="@color/dark_text_secondary"
            android:textSize="14sp" />

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:background="@color/dark_surface_variant">

        <ImageView
            android:id="@+id/btn_navigate_up"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_arrow_up"
            android:contentDescription="Navigate up"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/text_current_path"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:ellipsize="start"
            android:maxLines="1"
            android:textColor="@color/dark_text_secondary"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/btn_new_file"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_note_add"
            android:contentDescription="New file"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/btn_new_folder"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_create_new_folder"
            android:contentDescription="New folder"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/btn_refresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="Refresh"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_loading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- File tree -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_file_tree"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />

</LinearLayout>
